Content-Type: application/json

### Get tickets by status
GET http://localhost:8080/api/tickets/status/OPEN
Content-Type: application/json

### Get tickets by priority
GET http://localhost:8080/api/tickets/priority/HIGH
Content-Type: application/json

### Get tickets by category
GET http://localhost:8080/api/tickets/category/SOFTWARE
Content-Type: application/json

### Get tickets by creator ID
GET http://localhost:8080/api/tickets/creator/1
Content-Type: application/json

### Get tickets by technician ID
GET http://localhost:8080/api/tickets/technician/1
Content-Type: application/json

### Get unassigned tickets
GET http://localhost:8080/api/tickets/unassigned
Content-Type: application/json

################################
### LEAVES ENDPOINTS ###
################################

### Get all leaves
GET http://localhost:8080/api/leaves
Content-Type: application/json

### Get leave by ID
GET http://localhost:8080/api/leaves/1
Content-Type: application/json

### Get leaves by user ID
GET http://localhost:8080/api/leaves/user/1
Content-Type: application/json

### Get leaves by status
GET http://localhost:8080/api/leaves/status/APPROVED
Content-Type: application/json

### Get leaves by type
GET http://localhost:8080/api/leaves/type/VACATION
Content-Type: application/json

### Get pending leave requests
GET http://localhost:8080/api/leaves/pending
Content-Type: application/json

### Get leaves by approver ID
GET http://localhost:8080/api/leaves/approver/1
Content-Type: application/json

### Get leaves by date range
GET http://localhost:8080/api/leaves/date-range?startDate=2024-01-01&endDate=2024-12-31
Content-Type: application/json

