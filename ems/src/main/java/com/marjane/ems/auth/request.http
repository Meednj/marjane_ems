################################
### AUTHENTICATION & LOGIN ###
################################

### Login user
POST http://localhost:8080/api/users/login
Content-Type: application/json

{
  "eid": "E001",
  "password": "password123"
}

################################
### USERS ENDPOINTS ###
################################

### Get total user count
GET http://localhost:8080/api/users/count
Content-Type: application/json

################################
### EMPLOYEES ENDPOINTS ###
################################

### Get all employees
GET http://localhost:8080/api/employees
Content-Type: application/json

### Get employee by EID
GET http://localhost:8080/api/employees/E001
Content-Type: application/json

### Get employee by email
GET http://localhost:8080/api/employees/email/john.doe@company.com
Content-Type: application/json

### Get employees by department
GET http://localhost:8080/api/employees/department/IT
Content-Type: application/json

### Get employees by status
GET http://localhost:8080/api/employees/status/ACTIVE
Content-Type: application/json

################################
### ADMINISTRATORS ENDPOINTS ###
################################

### Get all administrators
GET http://localhost:8080/api/administrators
Content-Type: application/json

### Get administrator by EID
GET http://localhost:8080/api/administrators/A001
Content-Type: application/json

### Get administrator by email
GET http://localhost:8080/api/administrators/email/admin@company.com
Content-Type: application/json

